{
  "mcpServers": {
    "band": {
      "command": "band-mcp",
      "args": [
        "--scope",
        "agent,human",
        "--tools",
        "contacts"
      ],
      "env": {
        "BAND_AGENT_KEY": "band_a_your_agent_key",
        "BAND_USER_KEY": "band_u_your_user_key",
        "BAND_BASE_URL": "https://app.band.ai"
      }
    },
    "band_legacy": {
      "_comment": "Legacy single-key setup. Still supported; prefer BAND_USER_KEY / BAND_AGENT_KEY for new deployments.",
      "command": "band-mcp",
      "env": {
        "BAND_API_KEY": "your_api_key_here",
        "BAND_BASE_URL": "https://app.band.ai"
      }
    }
  }
}
